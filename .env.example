# 方式一：统一配置多个站点和模型（推荐）
# MONITOR_TARGETS 必须是 JSON 数组，示例：
# MONITOR_TARGETS=[{"name":"OpenAI GPT-4o mini","base_url":"https://api.openai.com/v1","api_key":"sk-xxx","model":"gpt-4o-mini"},{"name":"GLM 主站","base_url":"https://example.com/v1","api_key":"xxx","model":"GLM-5.1"},{"name":"Anthropic 兼容站点","base_url":"https://example.com","api_key":"sk-xxx","model":"claude-opus-4-1","request_format":"anthropic"}]

# 方式二：兼容旧版单站点配置
# API_BASE_URL=https://api.example.com/v1
# API_KEY=your_api_key
# API_MODEL=gpt-4o-mini

# 可选：本地守护进程检测间隔，单位秒
# CHECK_INTERVAL_SECONDS=600
